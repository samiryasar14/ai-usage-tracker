{
  "name": "ai-usage-tracker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "pnpm --filter @ai-usage-tracker/server dev",
    "dev:dashboard": "pnpm --filter @ai-usage-tracker/dashboard dev",
    "dev:desktop": "pnpm --filter @ai-usage-tracker/desktop dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @ai-usage-tracker/db generate",
    "db:migrate": "pnpm --filter @ai-usage-tracker/db migrate",
    "db:seed": "pnpm --filter @ai-usage-tracker/db seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "electron"
    ]
  }
}
