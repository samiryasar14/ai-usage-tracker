generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Provider {
  id       String   @id @default(cuid())
  name     String   @unique
  type     String
  status   String   @default("connected")
  models   Model[]
  sessions Session[]
}

model Model {
  id                    String   @id @default(cuid())
  providerId            String
  provider              Provider @relation(fields: [providerId], references: [id])
  name                  String
  contextWindow         Int
  inputPricePerMTok     Float
  outputPricePerMTok    Float
  cacheReadPricePerMTok Float
  cacheWritePricePerMTok Float
  // True when this model wasn't found in the pricing table, so cost was
  // recorded as 0 rather than a real (possibly wrong) number — surfaced in
  // the dashboard so spend totals aren't silently under-reported.
  pricingUnknown        Boolean  @default(false)
  requests              Request[]

  @@unique([providerId, name])
}

model Project {
  id          String    @id @default(cuid())
  path        String    @unique
  name        String
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  sessions    Session[]
}

model Session {
  id         String    @id @default(cuid())
  externalId String
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id])
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id])
  entrypoint String?
  startTime  DateTime
  endTime    DateTime
  requests   Request[]

  @@unique([providerId, externalId])
}

model Request {
  id                  String   @id @default(cuid())
  externalId          String   @unique
  sessionId           String
  session             Session  @relation(fields: [sessionId], references: [id])
  modelId             String
  model               Model    @relation(fields: [modelId], references: [id])
  timestamp           DateTime
  inputTokens          Int
  outputTokens         Int
  cacheReadTokens      Int
  cacheCreationTokens  Int
  cost                 Float
  // True for subagent/Task-tool turns, as opposed to the user-facing conversation.
  // Still counted in cost/token totals (it's real spend) — captured so future
  // reporting can separately attribute or filter delegated-agent usage.
  isSidechain          Boolean  @default(false)

  @@index([timestamp])
}

// Tracks how far into each append-only log file we've read, so ingestion
// can tail new lines instead of re-parsing the whole file every cycle.
model IngestCursor {
  filePath   String   @id
  byteOffset Int
  updatedAt  DateTime @updatedAt
}

model AlertRule {
  id           String       @id @default(cuid())
  type         String       // "monthly_budget" for now; extensible later
  thresholdUsd Float
  enabled      Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  events       AlertEvent[]
}

model AlertEvent {
  id             String    @id @default(cuid())
  rule           AlertRule @relation(fields: [ruleId], references: [id])
  ruleId         String
  // Dedup key for the period the alert covers, e.g. "2026-07" for a monthly
  // budget rule — ensures at most one alert per rule per month.
  periodKey      String
  triggeredAt    DateTime  @default(now())
  message        String
  acknowledgedAt DateTime?

  @@unique([ruleId, periodKey])
}

// Manually-tracked recurring subscriptions (ChatGPT Plus, Cursor Pro, GitHub
// Copilot, ...). These are fixed-cost plans, not usage events, so there's no
// provider plugin that can discover them automatically — the user enters them.
model Subscription {
  id             String    @id @default(cuid())
  name           String
  monthlyCostUsd Float
  // Day of month the plan renews, 1-31 (clamped to the month's actual length
  // when computing the next renewal date, e.g. day 31 in a 30-day month).
  renewalDay     Int
  status         String    @default("active") // "active" | "cancelled"
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Single global conversation with the in-app AI assistant (no multi-thread
// support yet — intentional v1 scope cut). See packages/server/src/assistant.ts.
model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// A mobile device paired to this desktop over the local network. Only the
// SHA-256 hash of its access token is stored (never the raw token) — see
// packages/server/src/pairing.ts.
model PairedDevice {
  id         String   @id @default(cuid())
  name       String
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
}
