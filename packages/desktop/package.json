{
  "name": "@ai-usage-tracker/desktop",
  "version": "0.5.0",
  "private": true,
  "license": "MIT",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder",
    "typecheck": "echo \"(desktop main process is plain JS — nothing to typecheck)\""
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.samiryasar.aiusagehub",
    "productName": "Soar AI Tracker",
    "directories": {
      "output": "release"
    },
    "files": ["src/**/*", "package.json"],
    "extraResources": [
      { "from": "../server/dist", "to": "server", "filter": ["**/*"] },
      { "from": "../server/deploy/node_modules", "to": "server/node_modules", "filter": ["**/*"] },
      { "from": "../db/prisma", "to": "server/prisma", "filter": ["schema.prisma", "migrations/**/*"] },
      { "from": "../dashboard/dist", "to": "dashboard", "filter": ["**/*"] }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "sysamiryasar",
      "repo": "soar-ai-tracker"
    }
  }
}
